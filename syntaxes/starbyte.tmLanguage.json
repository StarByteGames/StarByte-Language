{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "StarByte",
	"scopeName": "source.starbyte",
	"fileTypes": ["sb"],
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#preprocessor" },
		{ "include": "#strings" },
		{ "include": "#chars" },
		{ "include": "#numbers" },
		{ "include": "#constants" },
		{ "include": "#keywords-control" },
		{ "include": "#keywords-declaration" },
		{ "include": "#keywords-memory" },
		{ "include": "#types" },
		{ "include": "#function-definition" },
		{ "include": "#function-call" },
		{ "include": "#type-name" },
		{ "include": "#operators" },
		{ "include": "#punctuation" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.starbyte",
					"begin": "//",
					"end": "$",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.comment.starbyte" }
					}
				},
				{
					"name": "comment.block.starbyte",
					"begin": "/\\*",
					"end": "\\*/",
					"beginCaptures": {
						"0": { "name": "punctuation.definition.comment.begin.starbyte" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.definition.comment.end.starbyte" }
					}
				}
			]
		},
		"preprocessor": {
			"patterns": [
				{
					"name": "meta.preprocessor.starbyte",
					"match": "^\\s*(#(?:if|elif|else|endif|define|include))\\b",
					"captures": {
						"1": { "name": "keyword.control.directive.starbyte" }
					}
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.starbyte",
			"begin": "\"",
			"end": "\"",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.starbyte" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.starbyte" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.starbyte",
					"match": "\\\\(?:[ntr0\"'\\\\]|x[0-9A-Fa-f]{1,2}|u[0-9A-Fa-f]{1,4})"
				},
				{
					"name": "invalid.illegal.unknown-escape.starbyte",
					"match": "\\\\."
				}
			]
		},
		"chars": {
			"name": "string.quoted.single.starbyte",
			"begin": "'",
			"end": "'",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.starbyte" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.starbyte" }
			},
			"patterns": [
				{
					"name": "constant.character.escape.starbyte",
					"match": "\\\\(?:[ntr0\"'\\\\]|x[0-9A-Fa-f]{1,2})"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.hex.starbyte",
					"match": "\\b0[xX][0-9A-Fa-f]+\\b"
				},
				{
					"name": "constant.numeric.binary.starbyte",
					"match": "\\b0[bB][01]+\\b"
				},
				{
					"name": "constant.numeric.float.starbyte",
					"match": "\\b\\d+\\.\\d+(?:[eE][+-]?\\d+)?\\b"
				},
				{
					"name": "constant.numeric.float.starbyte",
					"match": "\\b\\d+[eE][+-]?\\d+\\b"
				},
				{
					"name": "constant.numeric.integer.starbyte",
					"match": "\\b\\d+\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.starbyte",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.null.starbyte",
					"match": "\\bnull\\b"
				}
			]
		},
		"keywords-control": {
			"name": "keyword.control.starbyte",
			"match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return)\\b"
		},
		"keywords-declaration": {
			"patterns": [
				{
					"name": "keyword.other.module.starbyte",
					"match": "\\b(module)\\b"
				},
				{
					"name": "storage.type.declaration.starbyte",
					"match": "\\b(struct|enum|class|interface|func)\\b"
				},
				{
					"name": "storage.modifier.starbyte",
					"match": "\\b(const|static|public|private|protected)\\b"
				},
				{
					"name": "keyword.other.inheritance.starbyte",
					"match": "\\b(extends|implements)\\b"
				},
				{
					"name": "keyword.other.new.starbyte",
					"match": "\\b(new)\\b"
				},
				{
					"name": "variable.language.this.starbyte",
					"match": "\\b(this|super)\\b"
				}
			]
		},
		"keywords-memory": {
			"patterns": [
				{
					"name": "keyword.other.memory.starbyte",
					"match": "\\b(alloc|free|gc_alloc|gc_collect|len)\\b"
				},
				{
					"name": "keyword.control.exception.starbyte",
					"match": "\\b(try|catch|finally|throw)\\b"
				}
			]
		},
		"types": {
			"name": "storage.type.primitive.starbyte",
			"match": "\\b(int|float|double|char|string|bool|void|byte|short|long|uint|ulong|ushort|sbyte)\\b"
		},
		"function-definition": {
			"comment": "Match: <type> <name>( ... )  — function definitions/declarations",
			"match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
			"captures": {
				"1": { "name": "storage.type.starbyte" },
				"2": { "name": "entity.name.function.starbyte" }
			}
		},
		"function-call": {
			"match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
			"captures": {
				"1": { "name": "entity.name.function.call.starbyte" }
			}
		},
		"type-name": {
			"comment": "PascalCase identifiers are treated as type/class names",
			"match": "\\b([A-Z][A-Za-z0-9_]*)\\b",
			"captures": {
				"1": { "name": "entity.name.type.starbyte" }
			}
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.compound.starbyte",
					"match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=)"
				},
				{
					"name": "keyword.operator.comparison.starbyte",
					"match": "(==|!=|<=|>=|<(?!<)|>(?!>))"
				},
				{
					"name": "keyword.operator.logical.starbyte",
					"match": "(&&|\\|\\||!(?!=))"
				},
				{
					"name": "keyword.operator.bitwise.starbyte",
					"match": "(<<|>>|&|\\||\\^|~)"
				},
				{
					"name": "keyword.operator.increment.starbyte",
					"match": "(\\+\\+|--)"
				},
				{
					"name": "keyword.operator.arithmetic.starbyte",
					"match": "(\\+|-|\\*|/|%)"
				},
				{
					"name": "keyword.operator.assignment.starbyte",
					"match": "="
				},
				{
					"name": "keyword.operator.ternary.starbyte",
					"match": "[?:]"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{ "name": "punctuation.terminator.statement.starbyte", "match": ";" },
				{ "name": "punctuation.separator.comma.starbyte", "match": "," },
				{ "name": "punctuation.accessor.starbyte", "match": "\\." }
			]
		}
	}
}